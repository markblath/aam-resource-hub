# Wild Apricot OAuth Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to git

WILD_APRICOT_CLIENT_ID=your_client_id_here
WILD_APRICOT_CLIENT_SECRET=your_client_secret_here
WILD_APRICOT_API_KEY=your_api_key_here
WILD_APRICOT_ACCOUNT_ID=your_account_id_here

# Redirect URI — use localhost for local dev, real URL for production
# Local:      http://localhost:3000/api/callback
# Production: https://aam-resource-hub.vercel.app/api/callback
WILD_APRICOT_REDIRECT_URI=https://aam-resource-hub.vercel.app/api/callback

# Secret used to sign session tokens (generate a random string, e.g. openssl rand -hex 32)
SESSION_SECRET=replace_with_a_long_random_string
